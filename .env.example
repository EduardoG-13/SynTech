# ──────────────────────────────────────────────────────────────
# BrPec — Syntech  ·  Variáveis de Ambiente
# ──────────────────────────────────────────────────────────────
# Copie este arquivo para .env antes de iniciar o servidor:
#   cp .env.example .env
# O arquivo .env NÃO deve ser versionado (já está no .gitignore).
# ──────────────────────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados local (SQLite)
# Caminho relativo à pasta src/backend/ — criado automaticamente na primeira execução
DB_PATH=./database/brpec.sqlite

# Banco de dados remoto (Supabase / PostgreSQL)
# Necessário apenas quando ENABLE_CLOUD_SYNC=true
DATABASE_URL=postgresql://usuario:senha@host:5432/database

# Sincronização em nuvem — defina como true para ativar (requer DATABASE_URL)
ENABLE_CLOUD_SYNC=false

# Segurança de sessão (OBRIGATÓRIO — nunca use o valor padrão em produção)
# Gere um valor único com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=substitua_por_valor_gerado_localmente

# Expiração de tokens JWT
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
