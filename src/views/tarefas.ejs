<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/tarefas.css" />

<div id="device" class="logged">

  <%- include('partials/sidebar') %>

  <div id="app">

    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><span class="material-symbols-rounded ui-icon" aria-hidden="true">engineering</span></div>
      <h1>Minhas Tarefas</h1>
      <div class="sub"><%= typeof nome !== 'undefined' ? nome : '' %> · <%= perfil %> · <%= retiro %></div>
    </div>

    <main class="tarefas-main">

      <!-- Filtros: Todos / Abertas / Pendentes / Aprovadas / Bloqueadas -->
      <div class="filter-pills hist-filtros-capataz" id="filtros-tarefas" style="display:flex; gap:0.4rem; overflow-x:auto; padding-bottom:0.25rem; margin-bottom:1rem; -webkit-overflow-scrolling:touch;">
        <button class="pill active" data-filtro="TODOS">Todos</button>
        <button class="pill" data-filtro="ABERTA"><span class="material-symbols-rounded ui-icon" aria-hidden="true">pending</span> Novas/Abertas <span class="contador badge-notif" id="badge-aberta" style="display:none; background:#D32F2F; color:#fff;">0</span></button>
        <button class="pill" data-filtro="PENDENTE"><span class="material-symbols-rounded ui-icon" aria-hidden="true">history</span> Pendentes <span class="contador badge-notif" id="badge-pendente" style="display:none; background:#D32F2F; color:#fff;">0</span></button>
        <button class="pill" data-filtro="CONCLUIDA"><span class="material-symbols-rounded ui-icon" aria-hidden="true">check_circle</span> Aprovadas</button>
        <button class="pill" data-filtro="BLOQUEADA"><span class="material-symbols-rounded ui-icon" aria-hidden="true">lock</span> Com Conflito <span class="contador badge-notif" id="badge-bloqueada" style="display:none; background:#D32F2F; color:#fff;">0</span></button>
      </div>

      <div class="tarefas-lista" id="tarefas-lista">
        <p style="text-align:center; color:#8A8A7C; padding:1rem;">Carregando...</p>
      </div>

      <div class="tarefas-vazio" id="tarefas-vazio" style="display:none;">
        <p> Nenhuma tarefa por aqui.</p>
      </div>

      <!-- Botão fixo flutuante: Nova Boleta/Tarefa -->
      <% if (perfil === 'Gerente' || perfil === 'Capataz') { %>
        <button class="btn btn-primario btn-fab" onclick="window.location.href='/nova-os'">
          <span class="material-symbols-rounded ui-icon btn-ico" aria-hidden="true">add</span> Nova Tarefa
        </button>
      <% } %>

    </main>
  </div>
</div>

<style>
  .filter-pills .pill .contador {
    background: rgba(255,255,255,0.25);
    padding: 1px 8px;
    border-radius: 999px;
    font-size: 0.75rem;
    margin-left: 0.4rem;
  }
  .filter-pills .pill:not(.active) .contador {
    background: #f0f0eb;
    color: #5c6b5d;
  }
  .badge.nova {
    background: #D32F2F;
    color: #fff;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-left: 0.4rem;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .badge.nova img { filter: brightness(0) invert(1); }
</style>

<script>
  var FILTRO = 'TODOS';
  var TODAS_TAREFAS = [];

  var ICO_TIPO = {
    nascimento: 'nascimento',
    obito: 'obto',
    transferencia: 'movimentacao',
    compravenda: 'cedula_dinheiro_bovino',
    evolucao: 'evolucao',
    manejo: 'tarefas',
  };
  var ROT_TIPO = {
    nascimento: 'Nascimento',
    obito: 'Morte',
    transferencia: 'Transferência',
    compravenda: 'Compra/Venda',
    evolucao: 'Evolução',
    manejo: 'Manejo',
  };

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('#filtros-tarefas .pill').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('#filtros-tarefas .pill').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        FILTRO = btn.dataset.filtro;
        renderizar();
      });
    });
    carregar();
  });

  // Helper: faz fetch e nunca rejeita — devolve fallback se der erro
  function buscarJson(url, fallback) {
    return fetch(url, { credentials: 'same-origin' })
      .then(function(r) { return r.ok ? r.json() : fallback; })
      .catch(function() { return fallback; });
  }

  function carregar() {
    // Busca tarefas abertas e concluídas do gerente, além das boletas do capataz
    Promise.all([
      buscarJson('/api/tarefas', { tarefas: [] }), // Traz todas as tarefas criadas pelo gerente para esse capataz
      buscarJson('/api/boletas/minhas', []), // Traz as boletas registradas por esse capataz
    ])
    .then(function(arr) {
      var tarefas = (arr[0] && arr[0].tarefas) || [];
      var boletas = (Array.isArray(arr[1]) ? arr[1] : []).map(function(b) {
        b._item = 'boleta';
        return b;
      });
      tarefas.forEach(function(t) { t._item = 'tarefa'; });

      // Junta tudo e ordena por data (mais recente primeiro)
      TODAS_TAREFAS = tarefas.concat(boletas);
      TODAS_TAREFAS.sort(function(a, b) {
        var da = new Date(a.data_execucao || a.data || 0).getTime();
        var db = new Date(b.data_execucao || b.data || 0).getTime();
        return db - da; // Mais recente primeiro
      });

      atualizarBadges(TODAS_TAREFAS);
      renderizar();
    });
  }

  function atualizarBadges(lista) {
    var cAberta = 0, cPendente = 0, cBloqueada = 0;
    lista.forEach(function(t) {
      if (t._item === 'tarefa') {
        if (t.status !== 'CONCLUIDA') cAberta++;
      } else {
        if (t.bloqueada) cBloqueada++;
        else if (!t.aprovada) cPendente++;
      }
    });
    document.getElementById('badge-aberta').style.display = cAberta > 0 ? 'inline' : 'none';
    document.getElementById('badge-aberta').textContent = cAberta;
    document.getElementById('badge-pendente').style.display = cPendente > 0 ? 'inline' : 'none';
    document.getElementById('badge-pendente').textContent = cPendente;
    document.getElementById('badge-bloqueada').style.display = cBloqueada > 0 ? 'inline' : 'none';
    document.getElementById('badge-bloqueada').textContent = cBloqueada;
  }

  function renderizar() {
    var cont = document.getElementById('tarefas-lista');
    var vazio = document.getElementById('tarefas-vazio');

    // Filtra a lista com base no FILTRO selecionado
    var lista = TODAS_TAREFAS.filter(function(t) {
      if (FILTRO === 'TODOS') return true;

      if (t._item === 'tarefa') {
        if (FILTRO === 'ABERTA') return t.status !== 'CONCLUIDA';
        if (FILTRO === 'CONCLUIDA') return t.status === 'CONCLUIDA';
        return false; // Tarefa não tem status 'bloqueada' ou 'pendente_aprovacao' (elas são ou abertas ou concluídas)
      } else {
        // Boleta
        var isBloqueada = !!t.bloqueada;
        var isAprovada = !!t.aprovada;
        var isPendente = !isAprovada && !isBloqueada;

        if (FILTRO === 'ABERTA') return false; // Boleta não é tarefa "Aberta/Nova" do gerente
        if (FILTRO === 'BLOQUEADA') return isBloqueada;
        if (FILTRO === 'CONCLUIDA') return isAprovada;
        if (FILTRO === 'PENDENTE') return isPendente;
        return false;
      }
    });

    if (!lista.length) {
      cont.innerHTML = '';
      vazio.style.display = 'block';
      return;
    }
    vazio.style.display = 'none';
    cont.innerHTML = lista.map(function(t) {
      return t._item === 'boleta' ? cardBoleta(t) : cardTarefa(t);
    }).join('');
  }

  // Card de TAREFA (agendada pelo gerente)
  function cardTarefa(t) {
    var ico = ICO_TIPO[t.tipo_operacao] || 'tarefas';
    var rotulo = ROT_TIPO[t.tipo_operacao] || t.tipo_operacao || 'Tarefa';
    var ehNova = (t.gerente_id && !t.vista_em && t.status !== 'CONCLUIDA');
    var badgeStatus = t.status === 'CONCLUIDA'
      ? '<span class="badge concluida"> Concluída</span>'
      : '<span class="badge pendente">' + (t.status === 'EM_ANDAMENTO' ? 'Em andamento' : 'Pendente') + '</span>';
    var badgeNova = ehNova
      ? '<span class="badge nova"><span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">notifications</span> NOVA</span>'
      : '';
    var prio = t.prioridade ? '<span class="prioridade ' + t.prioridade + '">● ' + t.prioridade.toUpperCase() + '</span>' : '';
    return '<div class="card tarefa-card" onclick="window.location.href=\'/tarefa/' + t.id + '\'">' +
      '<div class="bar-lateral ' + (t.status === 'CONCLUIDA' ? 'concluida' : 'pendente') + '"></div>' +
      '<div class="body"><div class="info">' +
        '<span class="titulo">' + BRPIcons.html(ico, 'label-ico') + ' ' + (t.titulo || rotulo) + ' ' + badgeNova + '</span>' +
        '<span class="descricao"> Tarefa · ' + rotulo + ' · ' + (t.retiro_nome || '') + '</span>' +
        '<div class="meta"><span class="retiro-tag"><span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">calendar_month</span> ' + (t.data_execucao || '') + '</span>' + prio + '</div>' +
      '</div><div class="status-area">' + badgeStatus + '<span class="arrow">›</span></div></div>' +
    '</div>';
  }

  // Card de BOLETA (registro criado pelo próprio capataz)
  function cardBoleta(b) {
    var ico = ICO_TIPO[b.operacao] || 'movimentacao';
    var rotulo = ROT_TIPO[b.operacao] || b.operacao || 'Boleta';
    var total = (b.animais || []).reduce(function(s, a) { return s + (parseInt(a.quantidade) || 0); }, 0);
    var badge = b.aprovada
      ? '<span class="badge concluida"> Aprovada</span>'
      : '<span class="badge pendente">Aguardando</span>';
    var num = b.numero_boleta ? ('<span style="font-size:0.7rem; font-weight:700; color:#5C6B5D;"> ' + b.numero_boleta + '</span>') : '';
    return '<div class="card tarefa-card" onclick="window.location.href=\'/boleta/' + b.id + '\'">' +
      '<div class="bar-lateral concluida"></div>' +
      '<div class="body"><div class="info">' +
        '<span class="titulo">' + BRPIcons.html(ico, 'label-ico') + ' ' + rotulo + (total ? ' — ' + total + ' cab.' : '') + ' ' + num + '</span>' +
        '<span class="descricao"> Boleta · ' + (b.retiro_nome || '') + '</span>' +
        '<div class="meta"><span class="retiro-tag"><span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">calendar_month</span> ' + (b.data || '') + '</span></div>' +
      '</div><div class="status-area">' + badge + '<span class="arrow">›</span></div></div>' +
    '</div>';
  }
</script>

<style>
  /* FAB Nova Boleta */
  .btn-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: auto;
    z-index: 100;
    box-shadow: 0 4px 16px rgba(26, 77, 46, 0.3);
    padding: 1rem 1.5rem;
    border-radius: 999px;
  }
  @media (max-width: 768px) {
    .btn-fab {
      bottom: 5rem;
      right: 1rem;
    }
  }
</style>

<%- include('partials/footer') %>
