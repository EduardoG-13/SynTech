{
  "name": "brpec-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend Node.js + Express da aplicacao BRPec Agropecuaria",
  "main": "server.js",
  "scripts": {
    "start": "ts-node server.ts",
    "dev": "npx nodemon --exec ts-node server.ts",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "setupFiles": [
      "./tests/setup.ts"
    ]
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
